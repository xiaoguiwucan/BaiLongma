{
  "name": "bailongma",
  "productName": "Bailongma",
  "version": "2.1.139",
  "description": "A continuously running digital consciousness framework",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "xiaoyuanda666-ship-it"
  },
  "scripts": {
    "start": "electron .",
    "start:lan": "node scripts/start-lan.mjs app",
    "start:backend": "node --env-file=.env src/index.js",
    "start:backend:lan": "node scripts/start-lan.mjs backend",
    "dev": "node --env-file=.env --watch src/index.js",
    "prebuild": "node scripts/prebuild-clean.mjs && node scripts/build-macos-speech.mjs",
    "build": "npm run build:mac",
    "build:mac": "npm run prebuild && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --mac",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/prebuild-clean.ps1 && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --win",
    "publish": "npm run publish:mac",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:win": "electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps",
    "smoke:tools": "node scripts/smoke-tools.mjs",
    "smoke:brain-ui": "node scripts/smoke-brain-ui.mjs",
    "smoke:social": "node scripts/smoke-social.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "electron-updater": "^6.3.9",
    "openai": "^6.34.0",
    "playwright": "^1.59.1",
    "wechat-ilink-client": "^0.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.xiaoyuanda.bailongma",
    "productName": "Bailongma",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/playwright/**",
      "**/node_modules/playwright-core/**",
      "src/voice/**",
      "build/native-speech-recognizer"
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "scripts/seed-memories.js",
      "index.html",
      "dashboard.html",
      "brain.html",
      "brain-ui.html",
      "website.html",
      "systemPrompt.html",
      "activation.html",
      "focus-banner.html",
      "build/icon.ico",
      "build/native-speech-recognizer",
      "sandbox/**/*",
      "music/**/*",
      "package.json",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts}",
      "!**/node_modules/.cache",
      "!**/.vscode",
      "!data/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Bailongma uses the microphone for voice input when you enable voice features.",
        "NSSpeechRecognitionUsageDescription": "Bailongma may use speech recognition for voice input features."
      },
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bailongma"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiaoyuanda666-ship-it",
        "repo": "BaiLongma",
        "releaseType": "release"
      }
    ]
  }
}
