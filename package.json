{
  "name": "bailongma",
  "productName": "Bailongma",
  "version": "2.3.1",
  "description": "A continuously running digital consciousness framework",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "xiaoguiwucan"
  },
  "scripts": {
    "start": "electron .",
    "start:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 app",
    "start:backend": "node --env-file=.env src/index.js",
    "start:backend:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 backend",
    "dev": "node --env-file=.env --watch src/index.js",
    "build": "npm run build:mac",
    "publish": "npm run publish:mac",
    "postinstall": "electron-builder install-app-deps",
    "smoke:tools": "node scripts/smoke-tools.mjs",
    "smoke:brain-ui": "node scripts/smoke-brain-ui.mjs",
    "smoke:social": "node scripts/smoke-social.mjs",
    "voice:events": "node scripts/voice-events-client.mjs",
    "smoke:voice-events": "node scripts/smoke-voice-events.mjs",
    "smoke:voice-mapping": "node scripts/smoke-voice-mapping.mjs",
    "smoke:voice-events-client": "node scripts/smoke-voice-events-client.mjs",
    "smoke:voice-config": "node scripts/smoke-voice-config.mjs",
    "smoke:wake-guard": "node scripts/smoke-wake-guard.mjs",
    "smoke:voice-manager": "node scripts/smoke-voice-manager.mjs",
    "build:mac": "node scripts/prebuild-clean.mjs && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --mac --arm64",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/prebuild-clean.ps1 && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --win",
    "publish:mac": "electron-builder --mac --arm64 --publish always",
    "publish:win": "electron-builder --win --publish always",
    "build:mac:x64": "node scripts/prebuild-clean.mjs && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --mac --x64",
    "publish:mac:x64": "electron-builder --mac --x64 --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "electron-updater": "^6.3.9",
    "openai": "^6.34.0",
    "wechat-ilink-client": "^0.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "com.xiaoyuanda.bailongma",
    "productName": "Bailongma",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "src/voice/**"
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "scripts/seed-memories.js",
      "index.html",
      "dashboard.html",
      "brain.html",
      "brain-ui.html",
      "website.html",
      "systemPrompt.html",
      "activation.html",
      "focus-banner.html",
      "build/icon.ico",
      "sandbox/**/*",
      "music/**/*",
      "package.json",
      "!**/*.map",
      "!src/test-*",
      "!src/**/test-*",
      "!scripts/smoke-*.mjs",
      "!src/**/__pycache__/**",
      "!src/**/*.pyc",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts}",
      "!**/node_modules/.cache",
      "!**/.vscode",
      "!data/**/*",
      "build/icon.icns"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bailongma"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiaoguiwucan",
        "repo": "BaiLongma",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
